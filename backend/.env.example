# Modelo de configuração. Copia este ficheiro para ".env" e preenche os valores.
# O ".env" real NÃO deve ser versionado no Git.

# Ligação à base de dados MySQL
DB_USER=root
DB_PASSWORD=
DB_SERVER=localhost
DB_NAME=projeto_picking

# Porta do servidor
PORT=3000

# Segredo para assinar os tokens JWT.
# Gera um valor longo e aleatório, por exemplo com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=coloca-aqui-uma-frase-secreta-longa-e-aleatoria
